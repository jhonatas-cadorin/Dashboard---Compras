rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Viewer');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Admin Master';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'status', 'permissions', 'createdAt'])
        && data.keys().size() == 7
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.role in ['Admin Master', 'Editor', 'Viewer', 'User']
        && data.status in ['Active', 'Inactive']
        && data.permissions is list
        && data.createdAt == request.time;
    }

    function isSystemConfigInitialized() {
      return get(/databases/$(database)/documents/system_config/settings).data.initialized == true;
    }

    // --- match Blocks ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        && (
          // Allow first user to be Admin Master if system not initialized
          (!exists(/databases/$(database)/documents/system_config/settings) && incoming().role == 'Admin Master')
          || (isSystemConfigInitialized() && incoming().role == 'Viewer')
        );

      allow update: if isSignedIn()
        && isValidId(userId)
        && (
          // Admin Master can update everything except restricted immutable fields
          (isAdmin() && incoming().uid == existing().uid && incoming().createdAt == existing().createdAt)
          || (
            // Users can update their own basic info (displayName)
            isOwner(userId) 
            && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
            && incoming().uid == existing().uid
            && incoming().email == existing().email
            && incoming().role == existing().role
            && incoming().status == existing().status
            && incoming().permissions == existing().permissions
          )
        );

      allow delete: if isAdmin() && userId != request.auth.uid; // Cannot delete self
    }

    // System Config
    match /system_config/settings {
      allow get: if isSignedIn(); // Needed for initialization check in frontend
      allow create: if isSignedIn() 
        && !exists(/databases/$(database)/documents/system_config/settings)
        && incoming().initialized == true
        && incoming().masterAdminUid == request.auth.uid;
      
      allow update: if isAdmin()
        && incoming().diff(existing()).affectedKeys().hasOnly(['initialized', 'masterAdminUid']);
      
      allow delete: if false;
    }

    // Logs
    match /logs/{logId} {
      allow create: if isSignedIn() 
        && isValidId(logId)
        && incoming().userId == request.auth.uid
        && incoming().timestamp == request.time;
      
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }
  }
}
