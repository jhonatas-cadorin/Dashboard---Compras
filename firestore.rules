rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Viewer');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole() == 'Admin Master';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'status', 'permissions', 'createdAt'])
        && (data.keys().size() == 7 || (data.keys().size() == 8 && data.get('password', '') is string))
        && data.uid is string
        && data.uid.size() <= 128
        && data.email is string
        && data.email.size() <= 200
        && data.displayName is string
        && data.displayName.size() <= 200
        && data.role in ['Admin Master', 'Editor', 'Viewer', 'User']
        && data.status in ['Active', 'Inactive']
        && data.permissions is list
        && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isSystemConfigInitialized() {
      return get(/databases/$(database)/documents/system_config/settings).data.initialized == true;
    }

    // --- match Blocks ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && isValidUser(incoming())
        && (
          // Case 1: First user initialized as Admin Master (system register)
          (!exists(/databases/$(database)/documents/system_config/settings) && userId == request.auth.uid && incoming().uid == request.auth.uid && incoming().role == 'Admin Master')
          // Case 2: User creating themselves (default option if logging in or offline registration)
          || (userId == request.auth.uid && incoming().uid == request.auth.uid && incoming().email == request.auth.token.email)
          // Case 3: Admin Master creating a user document
          || (isAdmin() && incoming().uid == userId)
        );

      allow update: if isSignedIn()
        && isValidId(userId)
        && (
          // Admin Master can update everything except restricted immutable fields
          (isAdmin() && incoming().uid == existing().uid && incoming().createdAt == existing().createdAt)
          || (
            // Users can update their own basic info (displayName)
            isOwner(userId) 
            && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
            && incoming().uid == existing().uid
            && incoming().email == existing().email
            && incoming().role == existing().role
            && incoming().status == existing().status
            && incoming().permissions == existing().permissions
          )
        );

      allow delete: if isAdmin() && userId != request.auth.uid; // Cannot delete self
    }

    // System Config
    match /system_config/settings {
      allow get: if isSignedIn(); // Needed for initialization check in frontend
      allow create: if isSignedIn() 
        && !exists(/databases/$(database)/documents/system_config/settings)
        && incoming().initialized == true
        && incoming().masterAdminUid == request.auth.uid;
      
      allow update: if isAdmin()
        && incoming().diff(existing()).affectedKeys().hasOnly(['initialized', 'masterAdminUid']);
      
      allow delete: if false;
    }

    // Logs
    match /logs/{logId} {
      allow create: if isSignedIn() 
        && isValidId(logId)
        && incoming().userId == request.auth.uid
        && incoming().timestamp == request.time;
      
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }
  }
}
